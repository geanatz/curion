{
  "name": "cortex-mcp-v2",
  "version": "0.1.0",
  "private": true,
  "description": "Cortex MCP v2 Phase 1 prototype infrastructure (project-local memory layer for AI agents)",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "cortex-mcp-v2": "dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "node --import tsx --test tests/*.test.ts",
    "test:contracts": "node --import tsx --test tests/contracts.test.ts",
    "start": "node dist/index.js",
    "clean": "rm -rf dist",
    "prototype": "tsx src/prototype/runner.ts",
    "prototype:dry": "tsx src/prototype/runner.ts --dry-run",
    "prototype:live": "tsx src/prototype/runner.ts --live",
    "benchmark:retrieval": "tsx src/benchmark/retrieval-runner.ts",
    "benchmark:retrieval:fts5": "tsx src/benchmark/retrieval-runner.ts --variant fts5",
    "benchmark:retrieval:vector": "tsx src/benchmark/retrieval-runner.ts --variant vector",
    "benchmark:retrieval:hybrid": "tsx src/benchmark/retrieval-runner.ts --variant hybrid",
    "benchmark:retrieval:hybrid:k20": "tsx src/benchmark/retrieval-runner.ts --variant hybrid --hybrid-k 20",
    "benchmark:retrieval:hybrid:k60": "tsx src/benchmark/retrieval-runner.ts --variant hybrid --hybrid-k 60",
    "benchmark:retrieval:hybrid:k100": "tsx src/benchmark/retrieval-runner.ts --variant hybrid --hybrid-k 100",
    "benchmark:retrieval:rrf": "npm run benchmark:retrieval:hybrid --silent",
    "benchmark:retrieval:all": "tsx src/benchmark/retrieval-runner.ts --variant all",
    "benchmark:retrieval:calibrate": "tsx src/benchmark/retrieval-runner.ts --variant all --calibrate",
    "benchmark:retrieval:calibrate:lexical": "tsx src/benchmark/retrieval-runner.ts --variant lexical --calibrate",
    "benchmark:retrieval:calibrate:fts5": "tsx src/benchmark/retrieval-runner.ts --variant fts5 --calibrate",
    "benchmark:retrieval:calibrate:vector": "tsx src/benchmark/retrieval-runner.ts --variant vector --calibrate",
    "benchmark:retrieval:calibrate:dense": "tsx src/benchmark/retrieval-runner.ts --variant all-dense --calibrate --embedder stub-dense",
    "benchmark:retrieval:calibrate:vector-dense": "tsx src/benchmark/retrieval-runner.ts --variant vector-dense --calibrate --embedder stub-dense",
    "benchmark:retrieval:calibrate:hybrid-dense": "tsx src/benchmark/retrieval-runner.ts --variant hybrid-dense --calibrate --embedder stub-dense",
    "benchmark:retrieval:calibrate:dense:real": "tsx src/benchmark/retrieval-runner.ts --variant all-dense --calibrate --embedder transformersjs",
    "benchmark:retrieval:vector-dense": "tsx src/benchmark/retrieval-runner.ts --variant vector-dense --embedder stub-dense",
    "benchmark:retrieval:vector-dense:real": "tsx src/benchmark/retrieval-runner.ts --variant vector-dense --embedder transformersjs",
    "benchmark:retrieval:vector-dense:skip": "tsx src/benchmark/retrieval-runner.ts --variant vector-dense --dense-skip",
    "benchmark:retrieval:hybrid-dense": "tsx src/benchmark/retrieval-runner.ts --variant hybrid-dense --embedder stub-dense",
    "benchmark:retrieval:hybrid-dense:real": "tsx src/benchmark/retrieval-runner.ts --variant hybrid-dense --embedder transformersjs",
    "benchmark:retrieval:all-dense": "tsx src/benchmark/retrieval-runner.ts --variant all-dense --embedder stub-dense",
    "benchmark:retrieval:all-dense:real": "tsx src/benchmark/retrieval-runner.ts --variant all-dense --embedder transformersjs",
    "benchmark:retrieval:abstention-audit": "tsx src/benchmark/retrieval-runner.ts --variant hybrid --abstention-audit",
    "benchmark:retrieval:abstention-audit:real": "tsx src/benchmark/retrieval-runner.ts --variant hybrid-dense --embedder transformersjs --abstention-audit",
    "benchmark:retrieval:abstention-audit:lexical": "tsx src/benchmark/retrieval-runner.ts --variant lexical --abstention-audit",
    "benchmark:retrieval:abstention-audit:fts5": "tsx src/benchmark/retrieval-runner.ts --variant fts5 --abstention-audit",
    "benchmark:retrieval:abstention-audit:vector": "tsx src/benchmark/retrieval-runner.ts --variant vector --abstention-audit",
    "benchmark:retrieval:abstention-audit:vector-dense": "tsx src/benchmark/retrieval-runner.ts --variant vector-dense --embedder stub-dense --abstention-audit",
    "benchmark:retrieval:abstention-audit:vector-dense:real": "tsx src/benchmark/retrieval-runner.ts --variant vector-dense --embedder transformersjs --abstention-audit",
    "benchmark:retrieval:abstention-audit:hybrid-dense:real": "tsx src/benchmark/retrieval-runner.ts --variant hybrid-dense --embedder transformersjs --abstention-audit",
    "benchmark:retrieval:abstention-policy": "tsx src/benchmark/retrieval-runner.ts --variant hybrid --abstention-policy",
    "benchmark:retrieval:abstention-policy:fts5": "tsx src/benchmark/retrieval-runner.ts --variant fts5 --abstention-policy",
    "benchmark:retrieval:abstention-policy:vector": "tsx src/benchmark/retrieval-runner.ts --variant vector --abstention-policy",
    "benchmark:retrieval:abstention-policy:hybrid-dense:real": "tsx src/benchmark/retrieval-runner.ts --variant hybrid-dense --embedder transformersjs --abstention-policy",
    "benchmark:retrieval:abstention-policy:all-dense:real": "tsx src/benchmark/retrieval-runner.ts --variant all-dense --embedder transformersjs --abstention-policy",
    "test:dense-live": "node --import tsx --test tests/_helpers/retrieval-dense-vector-live.test.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "better-sqlite3": "^12.10.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.10.0",
    "@xenova/transformers": "^2.17.2",
    "tsx": "^4.20.0",
    "typescript": "^5.7.2"
  }
}
