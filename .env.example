# Curion — local environment template
#
# Copy this file to `.env` and fill in real values for local prototype
# runs. Do NOT commit `.env`; the repo's `.gitignore` already excludes
# it. Only this `.env.example` file is safe to commit.
#
# No real API keys belong in this file. Placeholders only.
#
# --- Provider stance (NVIDIA-only) ----------------------------------------
#
# Curion's default runtime uses NVIDIA NIM as its ONLY configured
# provider. The architecture keeps a primary+fallback slot, but the
# fallback slot is empty by default — no provider is hardcoded into
# the fallback. If the primary engine is down, the adapter returns
# `provider_error` rather than silently routing to a different
# vendor.
#
# Tradeoff: a second engine (e.g. MiniMax) can still be enabled by
# setting the `CURION_MINIMAX_*` env vars + `MINIMAX_API_KEY` /
# `CURION_PROVIDER_FALLBACK_KEY`, but doing so is opt-in. A future
# Groq-based fallback is a separate evaluation; it is NOT part of
# the default runtime setup. The Groq prototype runner remains
# `prototype-only` (see "Prototype provider: Groq" below).

# --- General -----------------------------------------------------------------

# Minimum log level for the stderr logger: debug, info, warn, error.
CURION_LOG_LEVEL=info

# Project root override. Defaults to process.cwd() if unset.
# CURION_PROJECT_ROOT=/path/to/your/project

# --- Primary provider: NVIDIA NIM (default runtime) ------------------------
# This is the ONLY provider Curion uses by default. Both `remember`
# and `recall` route their primary chat-completions call here.
#
# CURION_PROVIDER_PRIMARY_KEY=
# NVIDIA_NIM_API_KEY=

# Base URL for the NVIDIA NIM OpenAI-compatible chat completions endpoint.
# Override only if you proxy or self-host; the default is the
# provider-published value used by the adapter.
# CURION_NIM_BASE_URL=https://integrate.api.nvidia.com/v1

# Primary model id for the production provider adapter. The
# `openai/gpt-oss-120b` model is the documented default for both
# `remember` and `recall`. The env-var name
# `CURION_NIM_FALLBACK_MODEL` is preserved for backward
# compatibility; under the NVIDIA-only stance, the value lands in
# the primary slot.
# CURION_NIM_FALLBACK_MODEL=openai/gpt-oss-120b

# Comma-separated NIM model candidates for the prototype runner
# only. The production provider adapter uses the single default
# above; the runner is prototype-only; the production MCP server
# does not consume this list. Override to compare additional models.
# CURION_NIM_MODELS=openai/gpt-oss-120b

# Per-request max output tokens for the prototype runner. Raise this
# for models that hit finish_reason=length on the structured-output
# fixtures (e.g. gpt-oss-120b on P3). Default 1024.
# CURION_PROTOTYPE_MAX_TOKENS=1024

# --- Fallback provider (OPT-IN, not default) -------------------------------
# The fallback slot is empty by default. Uncomment and fill the
# lines below to opt in to a second engine.
#
# When opted in, the adapter routes a hard-failed primary call to
# the fallback. The fallback is the only slot the MiniMax provider
# can occupy under the NVIDIA-only stance; there is no
# always-on MiniMax path.
#
# # MINIMAX_API_KEY=
# # CURION_PROVIDER_FALLBACK_KEY=
# # CURION_MINIMAX_BASE_URL=https://api.minimax.io/v1
# # CURION_MINIMAX_MODEL=MiniMax-M3

# --- Prototype runner knobs --------------------------------------------------
# Network timeout in milliseconds for provider HTTP calls.
# CURION_PROTOTYPE_TIMEOUT_MS=30000

# --- Provider adapter knobs --------------------------------------------------
# Per-request timeout (ms) and max output tokens for the provider
# adapter. Separate from CURION_PROTOTYPE_* so the adapter can be
# tuned without changing prototype-runner behavior.
# CURION_ADAPTER_TIMEOUT_MS=30000
# CURION_ADAPTER_MAX_TOKENS=1024

# --- Prototype provider: Groq -----------------------------------------------
# Optional candidate for the provider prototype comparison run.
# The runner reads these; the production provider adapter does not
# use Groq and Groq is NOT a configured fallback under the
# NVIDIA-only stance. Groq remains a prototype-only evaluation
# candidate; it is not promoted to a runtime fallback in this
# phase.
#
# GROQ_API_KEY=

# Base URL for the Groq OpenAI-compatible chat completions endpoint.
# CURION_GROQ_BASE_URL=https://api.groq.com/openai/v1

# Groq model id used by the prototype runner.
# CURION_GROQ_MODEL=openai/gpt-oss-120b

# Reasoning effort hint forwarded to the Groq chat completions
# request. Allowed values are provider-defined (e.g. low, medium, high).
# CURION_GROQ_REASONING_EFFORT=high

# --- Semantic retrieval (OPT-IN, not default) -------------------------------
# Semantic retrieval is an optional production feature. It is OFF by
# default (CURION_SEMANTIC_ENABLED defaults to false). When enabled,
# Curion uses a local dense embedder to compute semantic similarity
# in addition to the lexical ranker, and fuses the two rankings.
#
# The embedder runs entirely on-device (CPU, no GPU required). On
# first use it downloads a small ONNX model (~25 MB for the default
# Xenova/bge-small-en-v1.5) from the Hugging Face CDN and caches it
# locally. Subsequent runs use the local cache.
#
# Key behaviors when enabled:
# - remember() stores both the summary (lexical) and a dense vector.
# - recall() runs both lexical and semantic retrieval, then fuses
#   the rankings (RRF). This recovers paraphrase matches that the
#   token-overlap ranker misses.
# - If the embedder fails to load or the model cache is absent and
#   remote download is disabled (CURION_SEMANTIC_ALLOW_REMOTE=0),
#   semantic gracefully falls back to lexical-only. The core memory
#   functions (remember, recall) remain fully available.
# - Cross-project recall: non-private external projects may be
#   semantically searched. Mark a project private by adding
#   { "version": 1, "isPrivate": true } to .curion/config.json
#   in that project's root. Private projects are never surfaced.
#
# Memory model: the default embedder (Xenova/bge-small-en-v1.5)
# is quantized, 384-dim, and produces normalized vectors. The
# cache directory is <projectRoot>/.curion/transformers-cache/
# by default. Override with CURION_SEMANTIC_CACHE_DIR.
#
# Tradeoff: enabling semantic adds memory for the vector store and
# the first launch downloads the model cache (~25 MB). The benefit
# is better paraphrase recall via hybrid fusion.

# Set to "1" to enable semantic retrieval. Default: off (opt-in).
# CURION_SEMANTIC_ENABLED=1

# Allow remote model download from Hugging Face CDN when the local
# cache is absent. Default: true (remote allowed). Set to "0" to
# use only the local cache; if the model is not cached, the
# embedder falls back to lexical-only.
# CURION_SEMANTIC_ALLOW_REMOTE=1

# Local cache directory for the embedder's ONNX model files.
# Default: <projectRoot>/.curion/transformers-cache/
# CURION_SEMANTIC_CACHE_DIR=/path/to/custom/cache

# Hugging Face model id for the semantic embedder.
# Default: Xenova/bge-small-en-v1.5 (384-dim, quantized, ~25 MB).
# Other candidates (Qwen3, EmbeddingGemma, BGE-M3) are bench-
# marked separately and are not production defaults.
# CURION_SEMANTIC_MODEL_ID=Xenova/bge-small-en-v1.5
