# Build output
dist/
*.tsbuildinfo

# Dependencies
node_modules/

# Project-local Curion storage (per-project, not source-controlled)
.curion/

# Logs
*.log
npm-debug.log*

# Editor
.vscode/
.idea/

# Archived/exploratory work, kept locally but not source-controlled
.archive/

# Generated probe outputs in tmp/ (research scripts emit .jsonl and .md artifacts)
# Note: some .jsonl/.md files in tmp/ are already tracked research artifacts; gitignore
# does not untrack them, but new files of these types will be ignored by default.
tmp/*.jsonl
tmp/*.md

# Test coverage output
coverage/

# OS
.DS_Store
Thumbs.db

# Env files. .env.example is intentionally NOT ignored so it can be
# committed as a placeholder template. All other .env variants are
# gitignored because they may contain real secrets.
.env
.env.*
!.env.example
.env.local
.env.*.local

